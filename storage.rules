rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Banner/theme images live under organizations/{oid}/theme/...
    // Public read (banners are shown to all portal visitors); writes require auth.
    match /organizations/{organizationId}/theme/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else: deny by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
